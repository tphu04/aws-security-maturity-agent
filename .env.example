# =============================================================================
# PDCA AWS Security Agent — environment template
# =============================================================================
# Copy file này thành `.env` rồi điền giá trị thật. KHÔNG commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM (Ollama local)
# -----------------------------------------------------------------------------
OLLAMA_MODEL=gemma3:4b
OLLAMA_URL=http://localhost:11434
# OLLAMA_API_KEY=ollama   # dummy cho OpenAI-compat endpoint

# -----------------------------------------------------------------------------
# RAG service (FastAPI, port 8005)
# -----------------------------------------------------------------------------
RAG_API_URL=http://localhost:8005

# Multi-query RAG (xem RAG_API_URL docs)
MULTI_QUERY_MODE=true

# -----------------------------------------------------------------------------
# Scanner API (Prowler runner, port 8000)
# -----------------------------------------------------------------------------
SCANNER_API_URL=http://127.0.0.1:8000

# AWS credentials — quyền đọc + sửa resource cho remediation
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default

# -----------------------------------------------------------------------------
# Langfuse observability (Phase F — disabled mặc định)
# -----------------------------------------------------------------------------
# Master switch: false = không gửi observation, pipeline chạy nguyên.
LANGFUSE_ENABLED=false

# Credentials — bắt buộc khi LANGFUSE_ENABLED=true.
# Cloud signup: https://cloud.langfuse.com  (free tier 50K observations/tháng)
# Self-host:    https://langfuse.com/docs/deployment/self-host
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Redaction mode khi gửi data sang Langfuse:
#   full     — redact account_id + ARN + bucket name (bắt buộc cho cloud)
#   internal — chỉ redact AWS credentials (cho self-host private network)
#   off      — không redact (CI/test only — TUYỆT ĐỐI KHÔNG dùng prod)
LANGFUSE_REDACT_MODE=full

# Environment tag — filter trong UI: dev | staging | prod
LANGFUSE_ENVIRONMENT=dev

# Flush trace sau mỗi node — đảm bảo HITL pause không mất trace.
LANGFUSE_FLUSH_AT_NODE=true

# Circuit breaker — trip khi N flush fail liên tiếp trong window_s.
LANGFUSE_CIRCUIT_BREAKER_THRESHOLD=5
LANGFUSE_CIRCUIT_BREAKER_WINDOW_S=60

# Bench runner default OFF — bảo vệ quota cloud free tier.
LANGFUSE_BENCH_ENABLED=false

# Sample rate (0.0 - 1.0) — production self-host nên giữ 1.0.
LANGFUSE_SAMPLE_RATE=1.0

# HTTP request timeout (s) cho SDK init / flush — fail-fast để không block pipeline.
LANGFUSE_REQUEST_TIMEOUT_S=2.0

# -----------------------------------------------------------------------------
# Optional — LLM-as-Judge cho benchmark eval (không phần runtime pipeline)
# -----------------------------------------------------------------------------
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite
# GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-20b

# -----------------------------------------------------------------------------
# Optional — OpenRouter (legacy, đang phasing out)
# -----------------------------------------------------------------------------
# OPENROUTER_MODEL=
# OPENROUTER_API_KEY=
