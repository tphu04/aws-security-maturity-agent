# Langfuse self-host secrets — copy thành `.env` (cùng thư mục) rồi điền giá trị.
# Sinh tự động: bash scripts/generate-secrets.sh > .env

# === Bắt buộc — secrets ===
# 64 hex chars (openssl rand -hex 32)
ENCRYPTION_KEY=
# Random base64/hex (>= 32 chars). NextAuth session secret.
NEXTAUTH_SECRET=
# Random salt cho password hashing.
SALT=
# Postgres / Clickhouse / Redis / MinIO passwords (mỗi cái nên random riêng).
POSTGRES_PASSWORD=
# Phải khớp POSTGRES_PASSWORD ở trên — Langfuse cần connection string đầy đủ.
# Nếu password chứa @:/?# thì phải URL-encode (script đã tránh các ký tự này).
DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/postgres
CLICKHOUSE_PASSWORD=
REDIS_AUTH=
MINIO_ROOT_PASSWORD=
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=

# === Tùy chọn — host & port ===
# URL bên ngoài Langfuse Web (đổi nếu reverse proxy / domain).
NEXTAUTH_URL=http://localhost:3010
# Tránh đụng Postgres local của PDCA (5432) — Langfuse Postgres lệch sang 5433.
POSTGRES_HOST_PORT=5433
TELEMETRY_ENABLED=false

# === Tùy chọn — auto bootstrap project + API keys ===
# Nếu set đủ dưới đây, Langfuse sẽ tự tạo org/project/user/keys lần khởi động đầu.
# Tiện cho LVTN demo — không cần click UI.
LANGFUSE_INIT_ORG_ID=pdca-org
LANGFUSE_INIT_ORG_NAME=PDCA Lab
LANGFUSE_INIT_PROJECT_ID=pdca-aws-security
LANGFUSE_INIT_PROJECT_NAME=PDCA AWS Security Agent
# Public/secret key của project — chính là cặp dán vào PDCA `.env`.
# Format khuyến nghị: pk-lf-<random>, sk-lf-<random>.
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=admin@pdca.local
LANGFUSE_INIT_USER_NAME=PDCA Admin
# Mật khẩu user admin — chỉ dùng login UI, không phải API.
LANGFUSE_INIT_USER_PASSWORD=
